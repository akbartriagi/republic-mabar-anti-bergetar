<Window x:Class="RecoilHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Republic Mabar Anti Bergetar" Height="600" Width="880"
        MinHeight="520" MinWidth="760"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/logo.png"
        Background="#0D0D0F">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8080A0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2,8,2" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1C1C2C"/>
                                <Setter Property="Foreground" Value="#C0C0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#222236"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#9A86F8"/>
        </Style>

        <Style x:Key="TopBarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="BorderBrush" Value="#2A2A40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8080A0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#222238"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A4A70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarBtnActiveStyle" TargetType="Button" BasedOn="{StaticResource TopBarBtnStyle}">
            <Setter Property="Background" Value="#2A1A4A"/>
            <Setter Property="BorderBrush" Value="#7C6AF5"/>
            <Setter Property="Foreground" Value="#C0B0FF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border x:Name="TopBarBorder" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0D0D15"
                BorderBrush="#1A1A2A" BorderThickness="0,0,0,1"
                Padding="16,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="24" Height="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Republic Mabar Anti Bergetar" FontSize="15" FontWeight="SemiBold"
                               Foreground="#C0B0FF" VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                </StackPanel>

                <!-- Top bar actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnAlwaysOnTop"
                            Style="{StaticResource TopBarBtnStyle}"
                            Click="BtnAlwaysOnTop_Click" ToolTip="Always on Top">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📌" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtAOT" Text="Always on Top"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== SIDEBAR ===== -->
        <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="0"
                Width="210"
                Background="#0F0F18"
                BorderBrush="#1A1A28" BorderThickness="0,0,1,0"
                Visibility="Collapsed">
            <DockPanel LastChildFill="False">

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <Button x:Name="BtnDashboard"
                            Style="{StaticResource NavButtonActiveStyle}"
                            Click="BtnDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtNavDashboard" Text="Dashboard" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtNavSettings" Text="Settings" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAbout"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ" FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtNavAbout" Text="About" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status chip (bottom) -->
                <Border DockPanel.Dock="Bottom" Margin="10,0,10,14"
                        CornerRadius="8" Padding="12,10"
                        Background="#0C180C"
                        BorderBrush="#1A2A1A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TxtStatusLabel" Text="STATUS" FontSize="10" Foreground="#3A3A5A"
                                   FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Fill="#2A2A3A" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="INACTIVE"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#3A3A5A" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ===== CONTENT AREA ===== -->
        <Frame x:Name="MainFrame" 
               Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
               NavigationUIVisibility="Hidden"
               Background="#0D0D0F"/>
    </Grid>
</Window>
